{
  "name": "hotline-tauri",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:macos": "npm run tauri build -- --target universal-apple-darwin",
    "build:macos-intel": "npm run tauri build -- --target x86_64-apple-darwin",
    "build:macos-silicon": "npm run tauri build -- --target aarch64-apple-darwin",
    "build:macos-universal": "npm run tauri build -- --target universal-apple-darwin",
    "build:windows": "npm run tauri build -- --target x86_64-pc-windows-msvc",
    "build:linux": "npm run tauri build -- --target x86_64-unknown-linux-gnu",
    "build:linux-arm": "npm run tauri build -- --target aarch64-unknown-linux-gnu",
    "build:ios": "CI=false npm run tauri -- ios build",
    "build:ios-simulator": "CI=false npm run tauri -- ios build --simulator",
    "ios:init": "CI=false npm run tauri -- ios init",
    "ios:dev": "CI=false npm run tauri -- ios dev --open",
    "ios:dev:simulator": "CI=false npm run tauri -- ios dev \"iPad Pro 11-inch (M4)\"",
    "ios:dev:iphone": "CI=false npm run tauri -- ios dev --open",
    "ios:dev:iphone:simulator": "open -a Simulator && xcrun simctl boot A9C9C930-5460-4F31-96A7-0D506A4D310A 2>/dev/null || true && sleep 2 && CI=false npm run tauri -- ios dev --open",
    "ios:run": "CI=false npm run tauri -- ios run",
    "build:release": "./build-release.sh",
    "build:release-all": "./build-release-all.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
